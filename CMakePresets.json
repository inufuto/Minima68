{
  "version": 3,
  "configurePresets": [
    {
      "name": "windows-x64-debug",
      "hidden": false,
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-x64-release",
      "hidden": false,
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "pico",
      "hidden": false,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/pico",
      "cacheVariables": {
        "BUILD_FOR_PICO": "ON",
        "CMAKE_BUILD_TYPE": "Debug",
        "PICO_SDK_FETCH_FROM_GIT": "ON",
        "PICO_NO_PICOTOOL": "ON"
      }
    }
  ]
}
